{
  "name": "robot-whisperer",
  "version": "0.1.0",
  "description": "A Postman-style desktop and web client for ROS",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "web": "bun run build:wasm:dev && RW_TARGET=web vite dev --port 5173",
    "web:release": "bun run build && bun run preview",
    "build": "bun run build:wasm && RW_TARGET=web vite build",
    "build:native": "vite build",
    "build:wasm": "wasm-pack build src-tauri/crates/rw-wasm --target web --release --out-dir ../../../src/lib/wasm/generated",
    "build:wasm:dev": "wasm-pack build src-tauri/crates/rw-wasm --target web --dev --out-dir ../../../src/lib/wasm/generated",
    "preview": "RW_TARGET=web vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "cd src-tauri && RW_INTEGRATION=1 cargo nextest run --workspace --run-ignored only",
    "prepare": "lefthook install",
    "tauri": "tauri",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu --bundles appimage",
    "tauri:build:macos:arm": "tauri build --target aarch64-apple-darwin --bundles app,dmg",
    "tauri:build:macos:intel": "tauri build --target x86_64-apple-darwin --bundles app,dmg"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^0.542.0",
    "@tauri-apps/api": "^2",
    "tailwind-scrollbar": "^4.0.2",
    "three": "^0.184.0",
    "uplot": "^1.6.32",
    "urdf-loader": "^0.12.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.18.0",
    "eslint-plugin-svelte": "^3.0.0",
    "fake-indexeddb": "^6.0.1",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "lefthook": "^1.10.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
